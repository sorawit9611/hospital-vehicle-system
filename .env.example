# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (อย่า commit .env ขึ้น git)
# cp .env.example .env

# ── ฐานข้อมูล PostgreSQL ──
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hospital_vehicles"

# ── URL ของเว็บ (ใช้สร้าง QR code ของรถ) ──
# ⚠️ Production: ต้องเป็นที่อยู่จริงที่มือถือเข้าถึงได้ (IP/โดเมนของเซิร์ฟเวอร์)
#    ไม่งั้น QR ที่พิมพ์ออกมาจะชี้ไป localhost และสแกนไม่ได้
# ตัวอย่าง: "http://192.168.xxx.xxx:3000" หรือ "https://vehicle.hospital.local"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ── ระบบเข้าสู่ระบบผู้ดูแล ──
# รหัสผ่านสำหรับเข้า /admin
ADMIN_PASSWORD="เปลี่ยนเป็นรหัสผ่านที่ปลอดภัย"
# คีย์ลับสำหรับเซ็น session — สุ่มใหม่ด้วย: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="ใส่ค่าสุ่ม 64 ตัวอักษร"
